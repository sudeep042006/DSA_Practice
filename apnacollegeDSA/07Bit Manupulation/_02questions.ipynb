   "source": [
    "``Q1)  Check number is odd or even``"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "25066796",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "EVEN\n"
     ]
    }
   ],
   "source": [
    "int bitmask = 1;\n",
    "Scanner sc = new Scanner(System.in);\n",
    "int num = sc.nextInt();\n",
    "if((num & bitmask) == 0 ){\n",
    "    // even;\n",
    "    System.out.println(\"EVEN\");\n",
    "}\n",
    "else{\n",
    "    System.out.println(\"ODD\");\n",
    "}"
   ]
